# ============================================
# Kaggle API Credentials
# ============================================
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# ============================================
# Datasets
# ============================================
DATASET1=aguado/telemarketing-jyb-dataset
DATASET2=tunguz/bank-marketing-data-set
DATASET3=henriqueyamahata/bank-marketing
DATASET4=dharmik34/bank-term-deposit-subscription

# ============================================
# Data Paths
# ============================================
