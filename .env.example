# ============================================
# Simulation Parameters
# ============================================
SEED=42
BASE_DATE=2026-06-01
DELAY_SCALE_DAYS=2.0

# ============================================
# Bandit Policy Parameters
# ============================================
# Thompson Sampling
THOMPSON_ALPHA0=1.0
THOMPSON_BETA0=1.0

# UCB1
UCB1_EXPLORATION_BONUS=2.0

# Baseline
BASELINE_PREFERRED_ARM=0
